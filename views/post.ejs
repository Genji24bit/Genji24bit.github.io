<%- include('partials/head', { pageTitle: post.title }) %>

<article class="post-article">
  <div class="container">
    <!-- 文章头部 -->
    <header class="post-header" data-reveal>
      <% if (post.tags && post.tags.length > 0) { %>
      <div class="post-header-tags">
        <% post.tags.forEach(function(tag) { %>
          <a href="/blog?tag=<%= encodeURIComponent(tag) %>" class="tag"><%= tag %></a>
        <% }) %>
      </div>
      <% } %>
      <h1 class="post-title"><%= post.title %></h1>
      <div class="post-meta">
        <time datetime="<%= post.createdAt %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <%= new Date(post.createdAt).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }) %>
        </time>
        <span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          <%= post.views || 0 %> 阅读
        </span>
      </div>
    </header>

    <!-- 封面图 -->
    <% if (post.coverImage) { %>
    <div class="post-cover" data-reveal>
      <img src="<%= post.coverImage %>" alt="<%= post.title %>">
    </div>
    <% } %>

    <!-- 文章内容 -->
    <div class="post-content" data-reveal>
      <%- post.content %>
    </div>

    <!-- 文章底部 -->
    <footer class="post-footer" data-reveal>
      <div class="post-footer-tags">
        <% if (post.tags && post.tags.length > 0) { %>
          <span class="post-footer-label">标签：</span>
          <% post.tags.forEach(function(tag) { %>
            <a href="/blog?tag=<%= encodeURIComponent(tag) %>" class="tag"><%= tag %></a>
          <% }) %>
        <% } %>
      </div>
      <div class="post-footer-share">
        <span class="post-footer-label">分享：</span>
        <button class="share-btn" onclick="copyUrl()" title="复制链接">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </button>
      </div>
    </footer>
  </div>
</article>

<!-- 评论区 -->
<section class="section section-alt" id="comments">
  <div class="container">
    <div class="section-header" data-reveal>
      <span class="section-tag">Comments</span>
      <h2 class="section-title">
        评论
        <span class="comment-count"><%= comments.length %></span>
      </h2>
    </div>

    <!-- 评论列表 -->
    <div class="comments-list" data-reveal>
      <% if (comments.length > 0) { %>
        <% comments.forEach(function(c) { %>
        <div class="comment-item">
          <div class="comment-avatar">
            <span><%= c.name.charAt(0) %></span>
          </div>
          <div class="comment-body">
            <div class="comment-header">
              <strong class="comment-name"><%= c.name %></strong>
              <% if (c.email) { %><span class="comment-dot">·</span><span class="comment-email"><%= c.email %></span><% } %>
              <time class="comment-time"><%= new Date(c.createdAt).toLocaleDateString('zh-CN') %></time>
            </div>
            <p class="comment-content"><%= c.content %></p>
          </div>
        </div>
        <% }) %>
      <% } else { %>
      <div class="empty-state" style="padding: 2rem 0;">
        <div class="empty-icon">💬</div>
        <p>还没有评论，来留下你的想法吧</p>
      </div>
      <% } %>
    </div>

    <!-- Giscus 评论（GitHub Discussions 驱动，静态度部署时使用） -->
    <div class="comment-form-wrapper" data-reveal>
      <h3 class="comment-form-title">💬 加入讨论</h3>
      <div class="giscus" id="giscus-container"></div>
    </div>
  </div>
</section>

<!-- 相关文章 -->
<% if (related && related.length > 0) { %>
<section class="section">
  <div class="container">
    <div class="section-header" data-reveal>
      <span class="section-tag">Related</span>
      <h2 class="section-title">相关文章</h2>
    </div>
    <div class="posts-grid posts-grid-mini" data-reveal>
      <% related.forEach(function(r) { %>
      <article class="post-card">
        <a href="/blog/<%= r.id %>" class="post-card-link">
          <div class="post-card-body">
            <h3 class="post-card-title"><%= r.title %></h3>
            <div class="post-card-meta">
              <time><%= new Date(r.createdAt).toLocaleDateString('zh-CN') %></time>
            </div>
          </div>
        </a>
      </article>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<%- include('partials/footer') %>

<script>
// 复制链接
function copyUrl() {
  navigator.clipboard.writeText(window.location.href).then(() => {
    const btn = document.querySelector('.share-btn');
    const orig = btn.innerHTML;
    btn.innerHTML = '✅ 已复制';
    setTimeout(() => btn.innerHTML = orig, 2000);
  });
}
</script>

</body>
</html>
