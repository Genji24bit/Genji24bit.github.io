<%- include('partials/head', { pageTitle: '关于' }) %>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-content" data-reveal>
      <span class="section-tag">About</span>
      <h1 class="page-hero-title">关于我</h1>
      <p class="page-hero-desc">了解这个博客和它背后的创造者</p>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="about-layout" data-reveal>
      <!-- 个人简介 -->
      <div class="about-card about-profile">
        <div class="about-avatar-wrapper">
          <img src="<%= site.avatar %>" alt="<%= site.title %>" class="about-avatar">
          <div class="about-avatar-ring"></div>
        </div>
        <h2 class="about-name"><%= site.title %></h2>
        <p class="about-role"><%= site.subtitle %></p>
        <p class="about-bio">
          一个热爱设计与技术的创造者。相信优雅的代码和精美的设计能够改变世界。
          在这里记录我的思考、分享有用的资源，并与志同道合的朋友交流。
        </p>
        <div class="about-contact">
          <% if (site.social && site.social.email) { %>
          <a href="mailto:<%= site.social.email %>" class="btn btn-outline btn-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <%= site.social.email %>
          </a>
          <% } %>
          <% if (site.social && site.social.github) { %>
          <a href="<%= site.social.github %>" target="_blank" rel="noopener" class="btn btn-outline btn-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <% } %>
        </div>
      </div>

      <!-- 站点信息 -->
      <div class="about-card about-info">
        <h3 class="about-card-title">关于本站</h3>
        <ul class="about-list">
          <li>
            <span class="about-list-icon">✦</span>
            <div>
              <strong>博客名称</strong>
              <p><%= site.title %> — <%= site.subtitle %></p>
            </div>
          </li>
          <li>
            <span class="about-list-icon">📝</span>
            <div>
              <strong>内容领域</strong>
              <p>技术分享 · 设计思考 · 资源推荐 · 生活记录</p>
            </div>
          </li>
          <li>
            <span class="about-list-icon">🚀</span>
            <div>
              <strong>技术栈</strong>
              <p>Node.js · Express · EJS · CSS3 · JavaScript</p>
            </div>
          </li>
          <li>
            <span class="about-list-icon">🎨</span>
            <div>
              <strong>设计理念</strong>
              <p>简洁 · 优雅 · 响应式 · 暗色主题</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
