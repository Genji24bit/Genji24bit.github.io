<%- include('partials/head', { pageTitle: '资源' }) %>

<section class="page-hero">
  <div class="container">
    <div class="page-hero-content" data-reveal>
      <span class="section-tag">Resources</span>
      <h1 class="page-hero-title">资源下载</h1>
      <p class="page-hero-desc">精选实用资源 · 免费下载</p>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <!-- 工具栏 -->
    <div class="blog-toolbar" data-reveal>
      <form class="blog-search" action="/resources" method="GET">
        <svg class="blog-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" name="search" class="blog-search-input" placeholder="搜索资源..." value="<%= searchQuery || '' %>">
      </form>
      <% if (categories && categories.length > 0) { %>
      <div class="blog-tags">
        <a href="/resources" class="tag <%= activeCategory === 'all' ? 'tag-active' : '' %>">全部</a>
        <% categories.forEach(function(cat) { %>
          <a href="/resources?category=<%= encodeURIComponent(cat) %>" class="tag <%= activeCategory === cat ? 'tag-active' : '' %>"><%= cat %></a>
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- 资源列表 -->
    <% if (resources.length > 0) { %>
    <div class="resources-grid-full" data-reveal>
      <% resources.forEach(function(res, i) { %>
      <div class="resource-card-full" data-reveal data-delay="<%= i * 80 %>">
        <div class="resource-card-header">
          <div class="resource-card-icon-lg">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <div class="resource-card-info">
            <h3 class="resource-card-title"><%= res.title %></h3>
            <% if (res.category) { %><span class="tag"><%= res.category %></span><% } %>
          </div>
        </div>
        <p class="resource-card-desc"><%= res.description || '暂无描述' %></p>
        <div class="resource-card-actions">
          <div class="resource-card-stats">
            <span>📄 <%= res.fileName || '' %></span>
            <span>📦 <%= res.fileSize ? (res.fileSize / 1024 / 1024).toFixed(1) + ' MB' : '' %></span>
            <span>⬇ <%= res.downloads || 0 %> 次下载</span>
          </div>
          <a href="<%= res.filePath %>" class="btn btn-primary btn-sm download-btn"
             data-resource-id="<%= res.id %>"
             <%= res.filePath.startsWith('http') ? 'target="_blank" rel="noopener"' : 'download' %>>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            下载
          </a>
        </div>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div class="empty-state" data-reveal>
      <div class="empty-icon">📦</div>
      <h3><%= searchQuery ? '没有找到相关资源' : '还没有资源' %></h3>
      <p><%= searchQuery ? '没有与「' + searchQuery + '」相关的资源' : '资源正在准备中...' %></p>
      <% if (searchQuery) { %><a href="/resources" class="btn btn-outline" style="margin-top: 1rem;">查看全部</a><% } %>
    </div>
    <% } %>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // 下载计数
  document.querySelectorAll('.download-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const id = this.dataset.resourceId;
      if (id) {
        fetch('/api/resources/' + id + '/download', { method: 'POST' })
          .then(r => r.json())
          .then(data => {
            const stats = this.closest('.resource-card-actions').querySelector('.resource-card-stats');
            const dlSpan = stats.querySelector('span:last-child');
            if (dlSpan) dlSpan.textContent = '⬇ ' + data.downloads + ' 次下载';
          })
          .catch(() => {});
      }
    });
  });
});
</script>

<%- include('partials/footer') %>
</body>
</html>
